<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/widget_agenda_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/widget_agenda_label"
        android:textColor="@color/widget_accent"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_agenda_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/widget_no_courses_today"
        android:textColor="@color/widget_text_secondary"
        android:textSize="13sp" />

    <ListView
        android:id="@+id/widget_agenda_list"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="6dp"
        android:divider="@null"
        android:dividerHeight="0dp" />
</LinearLayout>
